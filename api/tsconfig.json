{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "typeRoots": [
      "../artifacts/api-server/node_modules/@types",
      "../node_modules/@types"
    ],
    "types": ["node", "express"]
  },
  "include": [
    "./**/*.ts",
    "../artifacts/api-server/src/**/*.ts"
  ]
}
