#!/bin/sh
# Pre-commit hook: TypeScript + ESLint check sebelum commit
# Setup: diaktifkan otomatis via `pnpm install` (prepare script)
# Skip darurat: git commit --no-verify

set -e

echo "⏳ [1/2] Typecheck..."
pnpm run typecheck
echo "✅ Typecheck lulus."

echo ""
echo "⏳ [2/2] Lint (ESLint)..."
pnpm run lint
echo "✅ Lint lulus."

echo ""
echo "🚀 Semua check lulus — melanjutkan commit."
