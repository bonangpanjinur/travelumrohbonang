{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "sh -c 'git config core.hooksPath .githooks && chmod +x .githooks/pre-commit || true'",
    "dev": "vite --config artifacts/umroh-app/vite.config.ts --host 0.0.0.0",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:dev": "vite build --config artifacts/umroh-app/vite.config.ts",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "eslint artifacts/umroh-app/src artifacts/api-server/src lib --ext .ts,.tsx",
    "lint:fix": "eslint artifacts/umroh-app/src artifacts/api-server/src lib --ext .ts,.tsx --fix",
    "verify:deploy-env": "node scripts/verify-deploy-env.mjs",
    "deploy:supabase": "node push-to-supabase.mjs"
  },
  "private": true,
  "dependencies": {
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/node": "25.9.4",
    "@vitejs/plugin-react": "^5.0.4",
    "@tailwindcss/vite": "^4.1.14",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.6",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.2"
  }
}
