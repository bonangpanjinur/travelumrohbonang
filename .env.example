# =============================================================
#  Environment Variables — Umroh App
#
#  Salin file ini ke .env untuk development lokal:
#    cp .env.example .env
#
#  Di Vercel: tambahkan semua variabel di bawah melalui
#    Project Settings → Environment Variables
# =============================================================

# ---------------------------------------------------------------
# DATABASE (Replit PostgreSQL — disediakan otomatis oleh Replit)
# ---------------------------------------------------------------

# Otomatis di-set oleh Replit; tidak perlu diisi manual di lingkungan Replit.
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ---------------------------------------------------------------
# REPLIT AUTH (login menggunakan akun Replit)
# ---------------------------------------------------------------

# REPL_ID dan REPLIT_DOMAINS disediakan otomatis oleh environment Replit.
# SESSION_SECRET disediakan otomatis oleh Replit sebagai secret.
# Daftar email admin (dipisah koma) yang otomatis mendapat role "admin":
ADMIN_EMAILS=admin@example.com

# ---------------------------------------------------------------
# SUPABASE (khusus untuk sebagian data query lama — TIDAK dipakai untuk auth lagi)
# Sekitar 74 file masih memanggil supabase.from(...) langsung untuk data;
# migrasi data tersebut ke Replit Postgres masih di luar cakupan saat ini.
# ---------------------------------------------------------------

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key   # sama dengan VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_PROJECT_ID=your-project-id               # bagian subdomain dari URL (mis. "abcdef" dari abcdef.supabase.co)

# ---------------------------------------------------------------
# API SERVER
# ---------------------------------------------------------------

# Port server Express — hanya untuk development lokal
PORT=8080

# URL API server dari sisi frontend:
#   - Kosongkan di Vercel (frontend & API satu domain, same-origin)
#   - Isi jika API di-deploy ke host terpisah, mis. https://api.yourdomain.com
VITE_API_URL=

# ---------------------------------------------------------------
# OPSIONAL
# ---------------------------------------------------------------

# Sentry — error monitoring (opsional)
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/xxx

# Cloudflare Turnstile — CAPTCHA (opsional)
# VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Level log API server: trace | debug | info | warn | error
# LOG_LEVEL=info
