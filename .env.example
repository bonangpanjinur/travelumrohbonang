# =============================================================
#  Environment Variables — Umroh App
#
#  Salin file ini ke .env untuk development lokal:
#    cp .env.example .env
#
#  Di Vercel: tambahkan semua variabel di bawah melalui
#    Project Settings → Environment Variables
# =============================================================

# ---------------------------------------------------------------
# DATABASE — Supabase PostgreSQL
# Dapatkan dari: Supabase Dashboard → Project Settings → Database
#                → Connection string → URI
# Pastikan mode: Transaction (port 6543) untuk serverless Vercel
# ---------------------------------------------------------------

DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------
# SUPABASE — Auth & realtime
# Dapatkan dari: Supabase Dashboard → Project Settings → API
#
# Cukup isi 4 variabel VITE_* di bawah — dipakai oleh frontend DAN
# server (server otomatis fallback ke variabel VITE_* jika versi
# tanpa-prefix tidak diisi). TIDAK perlu duplikat SUPABASE_URL /
# SUPABASE_ANON_KEY secara terpisah.
# ---------------------------------------------------------------

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key   # sama dengan VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_PROJECT_ID=your-project-id               # subdomain URL, mis. "abcdef" dari abcdef.supabase.co

# Wajib diisi terpisah (TIDAK punya varian VITE_ — rahasia server saja,
# jangan pernah diberi prefix VITE_ karena akan ikut ter-bundle ke frontend publik)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Opsional — isi hanya jika nilainya perlu BERBEDA dari VITE_SUPABASE_URL/ANON_KEY di atas
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# ---------------------------------------------------------------
# AUTH — TIDAK PERLU DIISI DI VERCEL
# Login aplikasi 100% pakai Supabase JWT (lihat variabel SUPABASE_*
# di atas). REPL_ID/ISSUER_URL hanya dipakai untuk dev-tool internal
# Replit dan otomatis nonaktif di production. Boleh dikosongkan.
# ---------------------------------------------------------------

# REPL_ID=
# ISSUER_URL=https://replit.com/oidc

# ---------------------------------------------------------------
# API SERVER
# ---------------------------------------------------------------

# Port server Express — hanya untuk development lokal
PORT=8080

# URL API server dari sisi frontend:
#   - Kosongkan di Vercel (frontend & API satu domain, same-origin)
#   - Isi jika API di-deploy ke host terpisah, mis. https://api.yourdomain.com
VITE_API_URL=

# Daftar origin yang diizinkan untuk CORS (comma-separated).
# Wajib diisi di production agar API tidak bisa diakses dari domain lain.
# Contoh: https://umrohplus.vercel.app,https://www.umrohplus.com
# Di development tidak perlu diisi (semua origin diizinkan secara otomatis).
ALLOWED_ORIGINS=https://your-app.vercel.app

# ---------------------------------------------------------------
# OPSIONAL
# ---------------------------------------------------------------

# Sentry — error monitoring (opsional)
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/xxx

# Cloudflare Turnstile — CAPTCHA (opsional)
# VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Level log API server: trace | debug | info | warn | error
# LOG_LEVEL=info

# ---------------------------------------------------------------
# UPTIME MONITORING (Vercel Cron)
# ---------------------------------------------------------------
# Vercel Cron memanggil GET /api/cron/health-check setiap 5 menit
# (lihat vercel.json). Jika database atau Supabase down, endpoint ini
# mengirim notifikasi ke webhook di bawah (jika di-set).

# Melindungi endpoint cron dari pemanggilan luar. Vercel otomatis
# mengirim header `Authorization: Bearer <CRON_SECRET>` saat memanggil
# cron job jika variabel ini di-set di Project Settings → Environment
# Variables. Generate nilai acak, contoh: openssl rand -hex 32
# CRON_SECRET=

# URL webhook untuk notifikasi saat health check degraded. Kompatibel
# dengan Slack Incoming Webhook atau Discord Webhook URL (keduanya
# menerima body JSON dengan field "text"/"content").
# ALERT_WEBHOOK_URL=

# ---------------------------------------------------------------
# VERIFIKASI SEBELUM DEPLOY
# ---------------------------------------------------------------
# Sebelum deploy ke Vercel, jalankan untuk memastikan semua variabel
# wajib di atas sudah lengkap:
#   pnpm run verify:deploy-env

