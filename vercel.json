{
  "buildCommand": "pnpm run typecheck && pnpm --filter @workspace/umroh-app run build",
  "outputDirectory": "artifacts/umroh-app/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
