{
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/umroh-app run build",
  "outputDirectory": "artifacts/umroh-app/dist/public",
  "functions": {
    "api/[...all].mjs": {
      "includeFiles": "artifacts/api-server/dist/**",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...all].mjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/document-reminder",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/follow-up",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/installment-reminder",
      "schedule": "0 1 * * *"
    }
  ]
}
